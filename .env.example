NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Google sign-in: enable in Supabase Dashboard (Auth → Providers → Google); no app env vars needed.
INNGEST_SIGNING_KEY=
HLI_APP_URL=
HLI_AUTO_QUEUE_AI=0
# Longevity module and API (set to 1 or true to enable login/portal and /api/longevity/*)
HLI_ENABLE_LONGEVITY=1
HLI_ENABLE_LONGEVITY_API=1
# HLI_ENABLE_LONGEVITY_LETTERS=1
# Longevity reminder email (Phase R): resend | console | none
# LONGEVITY_EMAIL_PROVIDER=none
# RESEND_API_KEY=
# LONGEVITY_EMAIL_FROM=Hair Longevity Institute <reminders@yourdomain.com>
# Optional: HLI letter/PDF branding (GP support letter, future blood letters, emails)
# HLI_BUSINESS_NAME=Hair Longevity Institute™
# HLI_TAGLINE=Clinical Hair & Scalp Science
# HLI_ADDRESS=123 Example St, City, State, Postcode
# HLI_EMAIL=contact@hairlongevityinstitute.com
# HLI_WEBSITE=https://hairlongevityinstitute.com
# HLI_PHONE=+61 2 0000 0000
# HLI_ABN=00 000 000 000
